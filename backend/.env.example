# ============================================================
# CRM Backend — Environment Variables
# Copy file này thành .env và điền giá trị thực
# ============================================================

NODE_ENV=development

# ── Database ────────────────────────────────────────────────
# Shared pool (standard tenants)
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm_dev

# Số connection tối đa cho shared pool (200 như thiết kế)
DATABASE_POOL_MAX=200

# App pool — Knex runtime queries. QUAN TRỌNG: phải là non-superuser để
# FORCE ROW LEVEL SECURITY hoạt động và đảm bảo tenant isolation.
# Tạo user: CREATE USER crm_app WITH PASSWORD 'crm_app' NOSUPERUSER;
#           GRANT CONNECT ON DATABASE crm_dev TO crm_app;
#           GRANT USAGE ON SCHEMA public TO crm_app;
#           GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO crm_app;
#           ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO crm_app;
DATABASE_APP_URL=postgresql://crm_app:crm_app@localhost:5432/crm_dev

# Metadata pool — system operations (migrations, tenant lookup)
DATABASE_METADATA_URL=postgresql://crm:crm@localhost:5432/crm_dev
DATABASE_METADATA_POOL_MAX=20

# ── Cache ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Message Broker ───────────────────────────────────────────
RABBITMQ_URL=amqp://crm:crm@localhost:5672

# ── App ──────────────────────────────────────────────────────
PORT=3000

# ── JWT / Auth ───────────────────────────────────────────────
# Option A: Keycloak JWKS (production)
# JWT_JWKS_URI=http://localhost:8080/realms/crm/protocol/openid-connect/certs
# JWT_ISSUER=http://localhost:8080/realms/crm
# JWT_AUDIENCE=crm-api

# Option B: Symmetric secret (dev/test — HS256)
# Bắt buộc phải set ít nhất một trong A hoặc B
JWT_SECRET_FALLBACK=change-me-minimum-32-chars-dev-secret-key

# ── Rate limiting ─────────────────────────────────────────────
THROTTLE_LIMIT=100
THROTTLE_TTL_MS=60000

# ── Logging ───────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── OpenTelemetry ─────────────────────────────────────────────
# OTLP HTTP endpoint — Jaeger all-in-one hoặc OTel Collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=crm-api
# Set true để disable OTel (dùng trong unit tests)
OTEL_DISABLED=false

# ── Metrics ───────────────────────────────────────────────────
# Interval cập nhật DB pool Prometheus gauges (ms)
POOL_METRICS_INTERVAL_MS=15000

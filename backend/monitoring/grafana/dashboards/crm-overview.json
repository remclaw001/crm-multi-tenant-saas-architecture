{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "CRM API — Request rate, latency, errors, DB pool utilization",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(crm_http_requests_total[1m])) by (tenant_tier)",
          "legendFormat": "{{tenant_tier}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (req/s) by Tenant Tier",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(crm_http_request_duration_seconds_bucket[5m])) by (le, tenant_tier))",
          "legendFormat": "p95 — {{tenant_tier}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(crm_http_request_duration_seconds_bucket[5m])) by (le, tenant_tier))",
          "legendFormat": "p50 — {{tenant_tier}}",
          "refId": "B"
        }
      ],
      "title": "Request Latency p50/p95 (seconds)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(crm_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(crm_http_requests_total[5m]))",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(crm_http_requests_total{status_code=~\"4..\"}[5m])) / sum(rate(crm_http_requests_total[5m]))",
          "legendFormat": "4xx Error Rate",
          "refId": "B"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 11,
      "title": "Database Pool",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "crm_db_pool_connections_total",
          "legendFormat": "total — {{pool_name}}",
          "refId": "A"
        },
        {
          "expr": "crm_db_pool_connections_idle",
          "legendFormat": "idle — {{pool_name}}",
          "refId": "B"
        },
        {
          "expr": "crm_db_pool_connections_waiting",
          "legendFormat": "waiting — {{pool_name}}",
          "refId": "C"
        }
      ],
      "title": "DB Connection Pool — Total / Idle / Waiting",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(crm_cache_operations_total[5m])) by (operation, result)",
          "legendFormat": "{{operation}} — {{result}}",
          "refId": "A"
        }
      ],
      "title": "Cache Operations (hit / miss)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 12,
      "title": "Node.js Runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "crm_nodejs_heap_size_used_bytes",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "crm_nodejs_heap_size_total_bytes",
          "legendFormat": "Heap Total",
          "refId": "B"
        }
      ],
      "title": "Node.js Heap Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "rate(crm_nodejs_eventloop_lag_seconds_sum[1m]) * 1000",
          "legendFormat": "Event Loop Lag (ms)",
          "refId": "A"
        }
      ],
      "title": "Event Loop Lag",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["crm", "api", "multi-tenant"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CRM API Overview",
  "uid": "crm-api-overview",
  "version": 1
}

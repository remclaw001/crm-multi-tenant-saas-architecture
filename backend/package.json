{
  "name": "crm-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CRM multi-tenant SaaS — backend",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node -r reflect-metadata src/main.ts",
    "build": "tsc -p tsconfig.json",
    "db:migrate": "node --require ts-node/register ./node_modules/.bin/knex --knexfile knexfile.ts migrate:latest",
    "db:migrate:rollback": "node --require ts-node/register ./node_modules/.bin/knex --knexfile knexfile.ts migrate:rollback",
    "db:migrate:rollback:all": "node --require ts-node/register ./node_modules/.bin/knex --knexfile knexfile.ts migrate:rollback --all",
    "db:seed": "node --require ts-node/register ./node_modules/.bin/knex --knexfile knexfile.ts seed:run",
    "db:reset": "npm run db:migrate:rollback:all && npm run db:migrate && npm run db:seed",
    "db:status": "node --require ts-node/register ./node_modules/.bin/knex --knexfile knexfile.ts migrate:status",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@elastic/elasticsearch": "^9.3.2",
    "@msgpack/msgpack": "^3.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@sentry/node": "^8.0.0",
    "@types/amqplib": "^0.10.8",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "amqplib": "^0.10.9",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.4.5",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "isolated-vm": "^6.0.2",
    "jwks-rsa": "^3.1.0",
    "knex": "^3.1.0",
    "nestjs-pino": "^4.3.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "ioredis-mock": "^8.9.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

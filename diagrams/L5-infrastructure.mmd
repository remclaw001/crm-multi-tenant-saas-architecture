classDiagram
    direction TB

    namespace PostgreSQL {
        class MetadataDB {
            <<external>>
            tenants
            tenant_plugins
            plugin_registry
            audit_log
        }

        class SharedDataDB {
            <<external>>
            RLS enabled
            3 read replicas
        }

        class VipDataDB {
            <<external>>
            1 per VIP tenant
        }
    }

    namespace Redis {
        class RedisCluster {
            <<external>>
            cache
            domain_map
            rate_limit
            token_blacklist
            pub_sub
        }

        class PgBouncer {
            <<external>>
            200 app conns to 50 DB conns
        }
    }

    namespace MessageQueue {
        class RabbitMQCluster {
            <<external>>
            exchange: crm.events
            exchange: crm.system
        }

        class WorkerPool {
            <<singleton>>
            notification 3w
            search_index 5w
            webhook 3w
            analytics 2w
            email 3w
        }
    }

    namespace SearchStorage {
        class ElasticsearchCluster {
            <<external>>
            per-tenant index
        }

        class S3ObjectStore {
            <<external>>
            SSE-KMS encrypted
        }

        class CDN {
            <<external>>
            edge cache per-version
        }
    }

    PgBouncer --> SharedDataDB : pool
    WorkerPool --> RabbitMQCluster : consume

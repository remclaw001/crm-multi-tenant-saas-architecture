classDiagram
    direction TB

    namespace CoreObservability {
        class ScopedLogger {
            <<per-request>>
            +debug()
            +info()
            +warn()
            +error()
            +withContext()
        }

        class TracingManager {
            <<singleton>>
            +startSpan()
            +endSpan()
            +setTag()
            +inject()
            +extract()
        }

        class MetricsCollector {
            <<singleton>>
            +observe()
            +increment()
            +gauge()
            +histogram()
        }

        class AlertManager {
            <<singleton>>
            +fire(alert)
            +resolve(alert)
            +escalate(alert)
        }
    }

    ScopedLogger --> TracingManager : inject traceId
    MetricsCollector --> AlertManager : threshold fire
    
    namespace HealthAudit {
        class LivenessProbe {
            <<singleton>>
            +check()
        }

        class ReadinessProbe {
            <<singleton>>
            +check()
        }

        class AuditTrailWriter {
            <<singleton>>
            +record(action, resource, before, after)
            +flush()
        }

        class AnomalyDetector {
            <<singleton>>
            +analyze(metrics)
            +detectCrossTenant()
            +detectSpike()
        }
    }

    AnomalyDetector --> AlertManager : pattern fire

classDiagram
    direction TB

    %% ═══════════════════════════════════════
    %% KEY CROSS-LAYER RELATIONSHIPS
    %% Only shows entities involved in cross-layer interactions.
    %% For full detail per-layer, see L1–L7 files.
    %% ═══════════════════════════════════════

    %% L2 → L5 (Gateway → Infrastructure)
    class TenantResolver
    class AuthGuard
    class RateLimiter
    class RouteMatcher
    class RedisCluster
    class MetadataDB

    TenantResolver --> RedisCluster : domain-map cache
    TenantResolver --> MetadataDB : fallback query
    AuthGuard --> RedisCluster : token blacklist
    RateLimiter --> RedisCluster : sorted set

    %% L2 → L3 (Gateway → Business Logic)
    class PluginRegistry
    class GatewayContext
    class TenantContextManager
    class ExecutionContextBuilder

    RouteMatcher --> PluginRegistry : routeTable lookup
    GatewayContext --> TenantContextManager : forwarded to
    GatewayContext --> ExecutionContextBuilder : forwarded to

    %% L3 → L4 (Business Logic → Data Access)
    class TenantScopedDB
    class TenantScopedCache
    class TenantInjector
    class QueryValidator
    class QueryCounter
    class QueryLogger
    class PoolRouter
    class L1MemoryCache
    class L2RedisCache

    TenantScopedDB --> TenantInjector : auto-inject tenant_id
    TenantScopedDB --> QueryValidator : 6 safety checks
    TenantScopedDB --> QueryCounter : track n_of_50
    TenantScopedDB --> QueryLogger : slow query log
    ExecutionContextBuilder --> PoolRouter : acquire DB conn
    TenantContextManager --> L1MemoryCache : LRU cache
    TenantScopedCache --> L2RedisCache : delegate

    %% L4 → L5 (Data Access → Infrastructure)
    class PoolRegistry
    class SharedDataDB
    class VipDataDB
    class PgBouncer
    class RabbitMQCluster

    PoolRegistry --> SharedDataDB : shared pool
    PoolRegistry --> VipDataDB : VIP pool
    PoolRegistry --> PgBouncer : connection mux
    PgBouncer --> SharedDataDB : pool

    L2RedisCache --> RedisCluster : cache ops

    %% L3 → L5 (Business Logic → Infrastructure)
    class MQPublisher
    class BroadcastManager
    class WorkerPool

    MQPublisher --> RabbitMQCluster : publish
    BroadcastManager --> RabbitMQCluster : fanout
    WorkerPool --> RabbitMQCluster : consume

    %% L3 → L4 (Plugin lifecycle → Migration)
    class PluginManager
    class SchemaMigrationRunner
    class TenantMigrationRunner

    PluginManager --> SchemaMigrationRunner : run DDL
    PluginManager --> TenantMigrationRunner : run DML

    %% L3/L4 → L6 (Cross-cutting consumption)
    class CircuitBreaker
    class RetryPolicy
    class ConfigResolver
    class DependencyResolver
    class ScopedLogger
    class PiiRedactor

    PoolRouter --> CircuitBreaker : fast-fail
    MQPublisher --> RetryPolicy : retry publish
    WorkerPool --> RetryPolicy : retry consume
    RateLimiter --> ConfigResolver : tier limits
    PluginManager --> DependencyResolver : enable/disable

    %% L3/L4 → L7 (Observability)
    class SandboxEngine
    class MetricsCollector
    class AuditTrailWriter
    class TracingManager
    class HealthChecker
    class ReadinessProbe

    ScopedLogger --> PiiRedactor : redact before ship
    ScopedLogger --> TracingManager : inject traceId
    SandboxEngine --> MetricsCollector : observe duration
    SandboxEngine --> AuditTrailWriter : record mutations
    AuditTrailWriter --> MetadataDB : batch INSERT
    HealthChecker --> ReadinessProbe : pool health

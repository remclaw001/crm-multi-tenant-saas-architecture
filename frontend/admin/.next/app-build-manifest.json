      "static/chunks/app/(dashboard)/tenants/page.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/page.js"
    ],
    "/(dashboard)/metrics/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/metrics/page.js"
    ],
    "/(dashboard)/tenants/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/tenants/[id]/page.js"
    ],
    "/(dashboard)/tenants/[id]/plugins/page": [
